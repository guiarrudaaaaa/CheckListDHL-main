rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /checklists/{documentId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Apenas checklists podem ser criados (sem update/delete público)
    match /checklists/{document} {
      allow create: if true;  // Permite criar novos checklists
      allow read: if true;    // Permite ler todos (para admin)
      allow delete: if true;  // Permite deletar (para admin)
    }

    // Bloqueia tudo o resto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}